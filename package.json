{
    "name": "whisper",
    "private": true,
    "workspaces": [
        "apps/*",
        "packages/*",
        "platforms/*"
    ],
    "scripts": {
        "dev": "bun run --filter @whisper/core dev",
        "build": "tsc --build",
        "test": "vitest run",
        "typecheck": "tsc --build",
        "lint": "biome check .",
        "format": "biome format --write ."
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.6",
        "@types/node": "^25.3.5",
        "typescript": "^5.9.3",
        "vitest": "^4.0.18"
    }
}
