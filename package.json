{
    "name": "whisper",
    "private": true,
    "workspaces": [
        "apps/*",
        "packages/*",
        "platforms/*"
    ],
    "scripts": {
        "dev": "bun run --filter @whisper/core dev",
        "dev:web": "bun run --filter web dev",
        "build": "bun run --filter @whisper/crypto build && bun run --filter @whisper/core build",
        "build:web": "bun run --filter web build",
        "format": "biome format --write .",
        "format:web": "biome format --write apps/web",
        "test": "vitest run",
        "typecheck": "bun run --filter @whisper/crypto typecheck && bun run --filter @whisper/core typecheck && bun run --filter web typecheck",
        "lint": "biome check .",
        "prepare": "lefthook install",
        "e2e": "playwright test",
        "e2e:chrome": "playwright test --project=chromium",
        "e2e:chrome:ui": "playwright test --project=chromium --ui",
        "e2e:ui": "playwright test --ui"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.6",
        "@playwright/test": "^1.58.2",
        "@types/node": "^25.4.0",
        "lefthook": "^2.1.4",
        "tsdown": "^0.21.2",
        "typescript": "^5.9.3",
        "vitest": "^4.0.18"
    }
}
