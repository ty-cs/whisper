{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "lib": [
            "ES2022",
            "DOM"
        ],
        "types": [
            "node"
        ],
        "paths": {
            "@whisper/core": [
                "./packages/core/src/app.ts"
            ],
            "@whisper/core/*": [
                "./packages/core/src/*"
            ],
            "@whisper/crypto": [
                "./packages/crypto/src/index.ts"
            ]
        }
    },
    "references": [
        {
            "path": "./packages/crypto"
        },
        {
            "path": "./packages/core"
        },
        {
            "path": "./platforms/vercel"
        }
    ],
    "files": [],
    "exclude": [
        "node_modules",
        "dist"
    ]
}