{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "lib": ["ES2022"],
        "paths": {
            "@whisper/crypto": ["./packages/crypto/src/index.ts"],
            "@whisper/core": ["./packages/core/src/index.ts"]
        }
    },
    "exclude": ["node_modules", "dist"]
}
