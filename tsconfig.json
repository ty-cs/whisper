{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "lib": ["ES2022"]
    },
    "references": [
        {
            "path": "./packages/crypto"
        },
        {
            "path": "./packages/core"
        },
        {
            "path": "./platforms/vercel"
        }
    ],
    "files": [],
    "exclude": ["node_modules", "dist"]
}
